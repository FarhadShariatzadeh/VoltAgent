# Database
DATABASE_URL=postgresql+asyncpg://voltagent:voltagent@localhost:5432/voltagent

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=change-me-to-a-random-32-byte-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Notifications (optional for local dev)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=alerts@voltagent.app
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# External Data APIs
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
ELECTRICITY_MAPS_API_KEY=
ELECTRICITY_MAPS_BASE_URL=https://api.electricitymap.org/v3

# App
APP_ENV=development
FRONTEND_URL=http://localhost:3001
